 async function comboLoad() {
        try{
        const res=await fetch(`/combobox`);
        let data= await res.json();
        let fields=data.fields;
        console.log(fields);
        

        fields.forEach(element=>{
            if (element.field_name==='state') {
             let select=document.getElementById('state');
             
            element.options.forEach(opt=>{
              let option=document.createElement('option');
              option.value=opt.value;
             option.text=opt.value ;
             select.appendChild(option)
            })

          }

             if (element.field_type==='radio') {
             let gender=document.getElementById('gender');
               
            element.options.forEach(opt=>{
                let label=document.createElement('label');
                label.innerText=opt.value;
              let input=document.createElement('input');
              input.type=element.field_type;
              input.name=element.field_name;
              input.id=opt.value;
              input.value=opt.value;

            gender.appendChild(label);
             gender.appendChild(input);
             
            })

          }

            if (element.field_name==='relationsjip_status') {
             let relation=document.getElementById('relation');
             
            element.options.forEach(opt=>{
              let option=document.createElement('option');
              option.value=opt.value;
             option.text=opt.value ;
             relation.appendChild(option)
            })

          }

             if (element.field_name==='course') {
             let select=document.getElementById('course');
             
            element.options.forEach(opt=>{
              let option=document.createElement('option');
              option.value=opt.value;
             option.text=opt.value ;
             select.appendChild(option)
             ;
            })

          }

          if (element.field_type==='checkbox') {
            let table=document.getElementById('languageTable');
               
            element.options.forEach(opt=>{
            
            let label=document.createElement('label');
            label.innerText=opt.value;
              let input=document.createElement('input');
              input.type=element.field_type;
              input.name=opt.value;
              input.id=opt.value;
              input.value=opt.value;
              table.appendChild(input);
              table.appendChild(label);

            })

          }

        });
      }catch(err){
        console.log(`Error in Fetching data`,err);   
      }   
    }       
    

