body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f4f7f6;
    color: #333;
    line-height: 1.6;
    padding: 20px;
}

h1 {
    color: #2c3e50;
    margin-bottom: 30px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
}

form {
    max-width: 1700px;
    margin: 0 auto;
    background: #fff;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}
 

fieldset {
    border: 1px solid #dcdde1;
    border-radius: 5px;
    padding: 20px;
    margin-bottom: 25px;
}

legend {
    font-weight: bold;
    padding: 0 10px;
    color: #2980b9;
    font-size: 1.1rem;
}


table {
    width: 100%;
    border-collapse: collapse;
}

td {
    padding: 8px 5px;
    vertical-align: middle;
}


input[type="text"],
input[type="date"],
input[type="currentCtc"], 
select {
    width: 90%;
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    box-sizing: border-box;
}

input[type="radio"] {
    margin-right: 5px;
    cursor: pointer;
}


#education, #workExperience {
    margin-top: 10px;
    text-align: center;
}

#education td, #workExperience td {
    border: 1px solid #eee;
    padding: 10px;
}

#education tr:first-child, 
#workExperience tr:first-child {
    background-color: #f8f9fa;
    font-weight: bold;
}


button {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 5px 12px;
    border-radius: 4px;
    cursor: pointer;
    margin: 5px;
    transition: background 0.3s ease;
}

button:hover {
    background-color: #2980b9;
}

input[type="submit"], 
input[type="reset"] {
    padding: 12px 30px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    margin-top: 20px;
}

input[type="submit"] {
    background-color: #27ae60;
    color: white;
}

input[type="submit"]:hover {
    background-color: #219150;
}

input[type="reset"] {
    background-color: #e74c3c;
    color: white;
    margin-left: 10px;
}

input[type="reset"]:hover {
    background-color: #c0392b;
}


#cityTrr {
    height: 50px;
}

label {
    font-size: 0.9rem;
    font-weight: 600;
}

</style>

